# E2E test credentials — copy this file to .env.e2e and fill in real values.
# .env.e2e is gitignored and will never be committed.
#
# The test account must exist in the running stack (http://localhost/).
# Create one via: http://localhost/register  or the Django admin panel.
#
# Playwright loads this file automatically if it is present in the frontend/ directory.

E2E_EMAIL=
E2E_PASSWORD=
