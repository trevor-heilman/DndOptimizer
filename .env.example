# Django Configuration
DJANGO_SECRET_KEY=changeme-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database Configuration
POSTGRES_DB=dndoptimizer
POSTGRES_USER=dnduser
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# For local development without Podman, use:
# POSTGRES_HOST=localhost

# Redis (used by Celery and caching)
REDIS_URL=redis://redis:6379/0
# For local development without Podman, use:
# REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend (only used when running frontend via Podman)
VITE_API_BASE_URL=http://localhost:8000/api
