# Default: normalize all text files to LF on checkout
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# Windows scripts are fine with CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
